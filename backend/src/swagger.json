{
  "openapi": "3.0.3",
  "info": {
    "title": "Styling with Muskan API",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:5000" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/auth/request-otp": {
      "post": {
        "summary": "Request OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "phone": { "type": "string" } }, "required": ["phone"] }
            }
          }
        },
        "responses": {
          "200": { "description": "OTP sent" },
          "400": { "description": "Validation errors" }
        }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "summary": "Verify OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "phone": { "type": "string" }, "otp": { "type": "string" } }, "required": ["phone", "otp"] }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated" },
          "400": { "description": "Invalid OTP or validation errors" }
        }
      }
    },
    "/users/me": {
      "get": { "summary": "Get current user", "responses": { "200": { "description": "User data" }, "401": { "description": "Unauthorized" } } },
      "patch": {
        "summary": "Update profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "name": { "type": "string" }, "referralCode": { "type": "string" } } }
            }
          }
        },
        "responses": { "200": { "description": "Updated" }, "400": { "description": "Validation errors" } }
      }
    },
    "/users/me/addresses": {
      "get": { "summary": "List addresses", "responses": { "200": { "description": "OK" } } },
      "post": {
        "summary": "Add address",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "houseNo": { "type": "string" }, "area": { "type": "string" }, "landmark": { "type": "string" }, "type": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" } },
                "required": ["houseNo", "area"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "400": { "description": "Validation errors" } }
      }
    },
    "/users/me/addresses/{id}": {
      "delete": {
        "summary": "Delete address",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/content/categories": {
      "get": {
        "summary": "List categories",
        "parameters": [{ "name": "gender", "in": "query", "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/content/services": {
      "get": {
        "summary": "List services",
        "parameters": [{ "name": "category", "in": "query", "schema": { "type": "string" } }, { "name": "gender", "in": "query", "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/bookings": {
      "get": {
        "summary": "List my bookings",
        "parameters": [{ "name": "page", "in": "query", "schema": { "type": "integer" } }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      },
      "post": {
        "summary": "Create booking",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": { "type": "array", "items": { "type": "object" } },
                  "slot": { "type": "object", "properties": { "date": { "type": "string" }, "time": { "type": "string" } }, "required": ["date", "time"] },
                  "address": { "type": "object", "properties": { "houseNo": { "type": "string" }, "area": { "type": "string" }, "landmark": { "type": "string" }, "lat": { "type": "number" }, "lng": { "type": "number" } }, "required": ["houseNo", "area"] },
                  "bookingType": { "type": "string" },
                  "couponCode": { "type": "string" }
                },
                "required": ["items", "slot", "address", "bookingType"]
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "400": { "description": "Validation errors" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/bookings/quote": {
      "post": {
        "summary": "Quote totals",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "items": { "type": "array" }, "couponCode": { "type": "string" } }, "required": ["items"] } } }
        },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Validation errors" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/bookings/{id}": {
      "get": {
        "summary": "Get booking",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/payments/razorpay/order": {
      "post": {
        "summary": "Create Razorpay order",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "amount": { "type": "integer" }, "currency": { "type": "string" }, "receipt": { "type": "string" } }, "required": ["amount"] } } }
        },
        "responses": { "200": { "description": "Order" }, "400": { "description": "Validation errors" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/payments/razorpay/verify": {
      "post": {
        "summary": "Verify Razorpay signature",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "order_id": { "type": "string" }, "payment_id": { "type": "string" }, "signature": { "type": "string" }, "bookingId": { "type": "string" }, "amount": { "type": "integer" } }, "required": ["order_id", "payment_id", "signature"] } } }
        },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Invalid signature" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/provider/request-otp": {
      "post": {
        "summary": "Provider request OTP",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "phone": { "type": "string" } }, "required": ["phone"] } } } },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Validation errors" } }
      }
    },
    "/provider/verify-otp": {
      "post": {
        "summary": "Provider verify OTP",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "phone": { "type": "string" }, "otp": { "type": "string" } }, "required": ["phone", "otp"] } } } },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Invalid OTP" } }
      }
    },
    "/provider/bookings/{id}/status": {
      "patch": {
        "summary": "Update booking status",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "status": { "type": "string" } }, "required": ["status"] } } } },
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/provider/bookings/{id}/verify-otp": {
      "post": {
        "summary": "Verify booking OTP",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "otp": { "type": "string" } }, "required": ["otp"] } } } },
        "responses": { "200": { "description": "OK" }, "403": { "description": "Invalid OTP" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/admin/settings": {
      "put": {
        "summary": "Update office settings",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "startTime": { "type": "string" }, "endTime": { "type": "string" }, "autoAssign": { "type": "boolean" } }, "required": ["startTime", "endTime", "autoAssign"] } } } },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Validation errors" }, "401": { "description": "Unauthorized" } }
      }
    }
  }
}
