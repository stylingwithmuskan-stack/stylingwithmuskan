# Core
NODE_ENV=development
PORT=3001

# MongoDB Atlas (recommended for "real data")
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB=swm

# Redis (OTP + caching). Use a hosted Redis in production.
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change_me
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Dev OTPs
DEMO_DEFAULT_PHONE=1234567890
DEMO_DEFAULT_OTP=1234
DEMO_DEFAULT_OTP6=123456

# Default OTP allowlist
DEFAULT_USER_OTP_PHONE=9990000001
DEFAULT_PROVIDER_OTP_PHONES=9100000001,9100000002,9100000003,9100000004
DEFAULT_VENDOR_OTP_PHONE=9999999999
DEFAULT_USER_OTP=1234
DEFAULT_PROVIDER_OTP=123456
DEFAULT_VENDOR_OTP=123456

# SMS India Hub
SMSINDIAHUB_BASE_URL=
SMSINDIAHUB_API_KEY=
SMSINDIAHUB_USERNAME=
SMSINDIAHUB_PASSWORD=
SMSINDIAHUB_SENDER_ID=
SMSINDIAHUB_ENTITY_ID=
SMSINDIAHUB_TEMPLATE_ID_4=
SMSINDIAHUB_TEMPLATE_ID_6=
SMSINDIAHUB_ROUTE=
SMSINDIAHUB_URL_TEMPLATE=
SMSINDIAHUB_MESSAGE_TEMPLATE_4=Your OTP is {otp}.
SMSINDIAHUB_MESSAGE_TEMPLATE_6=Your OTP is {otp}.

# Admin (dev defaults exist in code, but set explicitly for production)
ADMIN_EMAIL=admin@swm.local
ADMIN_PASSWORD=admin123

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
