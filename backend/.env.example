# Core
NODE_ENV=development
PORT=3001

# MongoDB Atlas (recommended for "real data")
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_DB=swm

# Redis (OTP + caching). Use a hosted Redis in production.
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=change_me
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Dev OTPs
DEMO_DEFAULT_PHONE=1234567890
DEMO_DEFAULT_OTP=1234
DEMO_DEFAULT_OTP6=123456

# Admin (dev defaults exist in code, but set explicitly for production)
ADMIN_EMAIL=admin@swm.local
ADMIN_PASSWORD=admin123

# Cloudinary (uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

